# ─────────────────────────────────────────────────────────────────────────────
# Backend environment. Copy to .env and fill in real values.
#   cp .env.example .env
# NEVER commit the real .env.
# ─────────────────────────────────────────────────────────────────────────────

# Secret used to sign internal values. Generate a strong one:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-me

# ── Database (PostgreSQL 13+) ────────────────────────────────────────────────
# Format: postgresql://<user>:<password>@<host>:<port>/<db>
# Percent-encode special chars in the password (@ -> %40, # -> %23, etc.)
# The app auto-creates the database + tables on first run.
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/timer_app_db

# ── Redis (server-side sessions) ─────────────────────────────────────────────
# Start one locally with Docker:
#   docker run -d --name timer-redis -p 6379:6379 redis:7-alpine redis-server --requirepass devredispass
REDIS_URL=redis://:devredispass@localhost:6379/0

# ── Sessions / cookies ───────────────────────────────────────────────────────
SESSION_TTL_SECONDS=1800          # 30 min, sliding
SESSION_COOKIE_NAME=session
CSRF_COOKIE_NAME=csrf_token
CSRF_HEADER_NAME=X-CSRF-Token
# MUST be true behind HTTPS in production. Keep false for local http.
COOKIE_SECURE=false

# ── Auth mode ────────────────────────────────────────────────────────────────
# development → enables one-click /api/auth/dev-login + the "login as" switcher
# production  → real Microsoft SSO only (dev endpoints return 404)
APP_ENV=development
DEV_AUTH_ENABLED=true

# Where the browser lands after login.
#  - dev / nginx (same origin): relative path
POST_LOGIN_PATH=/dashboard

# ── Microsoft Entra (only needed for real SSO; leave as-is for dev) ───────────
MICROSOFT_TENANT_ID=your-tenant-id
MICROSOFT_CLIENT_ID=your-client-id
MICROSOFT_CLIENT_SECRET=your-client-secret-VALUE
# Must EXACTLY match a "Web" redirect URI registered in Entra.
OAUTH_REDIRECT_URI=http://localhost:8000/api/auth/callback

# ── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000