# --- Core ---
SECRET_KEY=replace-with-output-of: python -c "import secrets; print(secrets.token_hex(32))"
DATABASE_URL=postgresql://postgres:YOUR_PG_PASSWORD@localhost:5432/timer_app_db
REDIS_URL=redis://:devredispass@localhost:6379/0

# --- Sessions / cookies ---
SESSION_TTL_SECONDS=1800
COOKIE_SECURE=false            # local dev is http; set true behind HTTPS

# --- Dev login (skips Microsoft) ---
APP_ENV=development            # enables /api/auth/dev-login
DEV_AUTH_ENABLED=true

# --- Microsoft (only needed for REAL SSO, safe to leave blank in dev) ---
MICROSOFT_TENANT_ID=your-tenant-id
MICROSOFT_CLIENT_ID=your-client-id
MICROSOFT_CLIENT_SECRET=your-client-secret
OAUTH_REDIRECT_URI=http://localhost:5173/api/auth/callback
POST_LOGIN_PATH=/time-tracker