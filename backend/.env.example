# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Secret key used to sign JWT tokens. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

#Server
HOST=0.0.0.0
PORT=8000

# Token expiry in minutes (default: 8 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Path to SQLite database file
DATABASE_URL=./timer_app.db

#Microsoft Authentication
MICROSOFT_TENANT_ID=your-tenant-id-here
MICROSOFT_CLIENT_ID=your-client-id-here

# Optional environment marker. Use development/local in non-production.
APP_ENV=development

# Development-only backend JWT endpoint toggle.
# Ignored when APP_ENV/ENVIRONMENT/ENV/NODE_ENV is production.
DEV_AUTH_ENABLED=false
