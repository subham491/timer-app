# ─────────────────────────────────────────────────────────────────────────────
# Frontend environment. Copy to .env:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# API base path. MUST stay relative so the app stays same-origin: the Vite dev
# proxy (vite.config.ts) forwards /api and /ws to the backend, and the session
# cookie + login redirect both depend on one origin. Never an absolute URL.
VITE_API_BASE_URL=/api